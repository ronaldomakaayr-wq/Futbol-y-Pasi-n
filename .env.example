PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_NAME=
# Set to "true" ONLY for quick prototyping. Production / shared DBs must use migrations.
DB_SYNCHRONIZE=false

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=1h

# CORS — frontend origin (Astro default port: 4321)
CORS_ORIGIN=http://localhost:4321

# Cloudinary (multimedia)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=campeonatos-dev
UPLOAD_MAX_BYTES=5242880
